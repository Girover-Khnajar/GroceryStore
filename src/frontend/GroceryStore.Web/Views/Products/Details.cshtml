@model ProductDetailViewModel
@using System.Globalization
@using System.Resources
@{
    var sharedResourceManager = new ResourceManager("GroceryStore.Web.Shared.SharedResource", typeof(GroceryStore.Web.Controllers.HomeController).Assembly);
    string T(string key) => sharedResourceManager.GetString(key, CultureInfo.CurrentUICulture) ?? key;
    ViewData["Title"] = Model.Product.Name;
}

<section class="section" style="padding-top: calc(var(--nav-height) + 2rem);">
    <div class="container">
        @* Breadcrumb *@
        <nav class="breadcrumb">
            <a asp-controller="Home" asp-action="Index">@T("Nav_Home")</a>
            <span style="margin:0 .4rem;">/</span>
            <a asp-controller="Products" asp-action="Index">@T("Nav_Products")</a>
            @if (Model.CategoryName is not null)
            {
                <span style="margin:0 .4rem;">/</span>
                <span>@Model.CategoryName</span>
            }
            <span style="margin:0 .4rem;">/</span>
            <span style="color:var(--text);">@Model.Product.Name</span>
        </nav>

        @* ═══ Product Detail Grid ═══ *@
        <div class="product-detail-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;margin-top:1rem;">

            @* ── Image Gallery ── *@
            <div>
                @{
                    var mainImage = Model.PrimaryImageUrl;
                }
                <div style="background:var(--surface);border-radius:var(--radius-xl);border:1px solid var(--border);overflow:hidden;aspect-ratio:1;">
                    @if (!string.IsNullOrWhiteSpace(mainImage))
                    {
                        <img id="mainImage" src="@mainImage" alt="@Model.Product.Name"
                             style="width:100%;height:100%;object-fit:cover;" />
                    }
                    else
                    {
                        <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:var(--surface-alt);color:var(--text-light);">
                            <i class="fas fa-box-open" style="font-size:3rem;"></i>
                        </div>
                    }
                </div>

                @* Thumbnails *@
                @if (Model.ImageUrls.Count > 1)
                {
                    <div style="display:flex;gap:.5rem;margin-top:1rem;flex-wrap:wrap;">
                    @foreach (var thumb in Model.ImageUrls)
                    {
                        <div style="width:64px;height:64px;border-radius:var(--radius-sm);overflow:hidden;border:2px solid var(--border);cursor:pointer;"
                             onclick="document.getElementById('mainImage').src='@thumb'">
                            <img src="@thumb" alt="@Model.Product.Name"
                                 style="width:100%;height:100%;object-fit:cover;" />
                        </div>
                    }
                    </div>
                }
            </div>

            @* ── Product Info ── *@
            <div>
                @if (Model.Product.IsFeatured)
                {
                    <span class="badge-featured" style="position:static;margin-bottom:1rem;display:inline-flex;">
                        <i class="fas fa-star"></i> @T("Badge_Featured")
                    </span>
                }

                <h1 style="font-size:clamp(1.5rem,3vw,2.25rem);font-weight:800;margin-bottom:.5rem;">
                    @Model.Product.Name
                </h1>

                @if (Model.CategoryName is not null || !string.IsNullOrWhiteSpace(Model.Product.Brand))
                {
                    <div style="display:flex;gap:1rem;flex-wrap:wrap;color:var(--text-light);font-size:.9rem;margin-bottom:1rem;">
                        @if (Model.CategoryName is not null)
                        {
                            <span><i class="fas fa-tag"></i> @Model.CategoryName</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.Product.Brand))
                        {
                            <span><i class="fas fa-industry"></i> @Model.Product.Brand</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.Product.Sku))
                        {
                            <span><i class="fas fa-barcode"></i> @Model.Product.Sku</span>
                        }
                    </div>
                }

                @* Price *@
                <div style="display:flex;align-items:baseline;gap:.5rem;margin-bottom:1.5rem;">
                    <span style="font-size:1.75rem;font-weight:800;color:var(--primary);">
                        @Model.Product.PriceAmount.ToString("N2") @Model.Product.PriceCurrency
                    </span>
                    @if (!string.IsNullOrWhiteSpace(Model.Product.Unit))
                    {
                        <span style="color:var(--text-light);font-size:.9rem;">/ @Model.Product.Unit</span>
                    }
                </div>

                @* Short description *@
                @if (!string.IsNullOrWhiteSpace(Model.Product.ShortDescription))
                {
                    <p style="color:var(--text-light);line-height:1.7;margin-bottom:1.5rem;">
                        @Model.Product.ShortDescription
                    </p>
                }

                @* Badges *@
                <div style="display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:1.5rem;">
                    @if (Model.Product.IsOrganic == true)
                    {
                        <span style="display:inline-flex;align-items:center;gap:.3rem;padding:.4rem .8rem;background:#dcfce7;color:#15803d;border-radius:20px;font-size:.8rem;font-weight:600;">
                            <i class="fas fa-leaf"></i> @T("Badge_Organic")
                        </span>
                    }
                    @if (Model.Product.IsVegan == true)
                    {
                        <span style="display:inline-flex;align-items:center;gap:.3rem;padding:.4rem .8rem;background:#d1fae5;color:#047857;border-radius:20px;font-size:.8rem;font-weight:600;">
                            <i class="fas fa-seedling"></i> @T("Badge_Vegan")
                        </span>
                    }
                    @if (Model.Product.IsHalal == true)
                    {
                        <span style="display:inline-flex;align-items:center;gap:.3rem;padding:.4rem .8rem;background:#dbeafe;color:#2563eb;border-radius:20px;font-size:.8rem;font-weight:600;">
                            <i class="fas fa-check-circle"></i> @T("Badge_Halal")
                        </span>
                    }
                </div>

                @* Add to Cart *@
                <div style="display:flex;gap:1rem;flex-wrap:wrap;margin-bottom:2rem;">
                    <button type="button" class="btn-whatsapp" style="padding:1rem 1.5rem;font-size:1rem;"
                            onclick="addToCart(event, '@Model.Product.Id')">
                        <i class="fas fa-cart-plus"></i> @T("Btn_AddToCart")
                    </button>
                    <a asp-controller="Cart" asp-action="Index" class="btn-secondary" style="padding:1rem 1.5rem;font-size:1rem;">
                        <i class="fas fa-shopping-cart"></i> @T("Btn_ViewCart")
                    </a>
                </div>

                @* Long description *@
                @if (!string.IsNullOrWhiteSpace(Model.Product.LongDescription))
                {
                    <div style="border-top:1px solid var(--border);padding-top:1.5rem;">
                        <h3 style="font-size:1.1rem;font-weight:700;margin-bottom:.75rem;">@T("Lbl_Description")</h3>
                        <p style="color:var(--text-light);line-height:1.8;">@Model.Product.LongDescription</p>
                    </div>
                }

                @* Tags *@
                @if (Model.Product.Tags.Count > 0)
                {
                    <div style="margin-top:1.5rem;display:flex;gap:.5rem;flex-wrap:wrap;">
                        @foreach (var tag in Model.Product.Tags)
                        {
                            <span style="padding:.3rem .8rem;background:var(--surface-alt);border:1px solid var(--border);border-radius:20px;font-size:.8rem;color:var(--text-light);">
                                @tag
                            </span>
                        }
                    </div>
                }

                @* Allergens *@
                @if (Model.Product.Allergens.Count > 0)
                {
                    <div style="margin-top:1rem;display:flex;gap:.5rem;flex-wrap:wrap;">
                        <span style="font-size:.85rem;font-weight:600;color:var(--danger);">@T("Products_Allergens"):</span>
                        @foreach (var a in Model.Product.Allergens)
                        {
                            <span style="padding:.3rem .8rem;background:#fef2f2;color:var(--danger);border-radius:20px;font-size:.8rem;">
                                @a
                            </span>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</section>
