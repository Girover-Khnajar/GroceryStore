@model StoreSettingsViewModel
@using System.Globalization
@using System.Resources
@{
    Layout = "_AdminLayout";
    var sharedResourceManager = new ResourceManager("GroceryStore.Web.Shared.SharedResource", typeof(GroceryStore.Web.Controllers.HomeController).Assembly);
    string T(string key) => sharedResourceManager.GetString(key, CultureInfo.CurrentUICulture) ?? key;
    ViewData["Title"] = T("Admin_StoreSettings");
}

<h2 style="margin-bottom:2rem;font-size:1.5rem;font-weight:700;">
    <i class="fas fa-cog" style="color:var(--primary);margin-right:.5rem;"></i>
    @T("Admin_StoreSettings")
</h2>

<div style="background:var(--surface);border-radius:var(--radius-lg);border:1px solid var(--border);padding:2.5rem;max-width:680px;">
    <form asp-action="Settings" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:1rem;"></div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;">
            <div class="form-group" style="grid-column:1/-1;">
                <label asp-for="StoreName" class="form-label">@T("Admin_Settings_StoreName")</label>
                <input asp-for="StoreName" class="form-control" placeholder="@T("Admin_Settings_StoreNamePlaceholder")" />
                <span asp-validation-for="StoreName" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label asp-for="Phone" class="form-label">@T("Admin_Settings_Phone")</label>
                <input asp-for="Phone" class="form-control" placeholder="@T("Admin_Settings_PhonePlaceholder")" />
                <span asp-validation-for="Phone" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label asp-for="WhatsappNumber" class="form-label">@T("Admin_Settings_Whatsapp")</label>
                <input asp-for="WhatsappNumber" class="form-control" placeholder="@T("Admin_Settings_WhatsappPlaceholder")" />
                <span asp-validation-for="WhatsappNumber" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email" class="form-label">@T("Admin_Settings_Email")</label>
                <input asp-for="Email" class="form-control" placeholder="@T("Admin_Settings_EmailPlaceholder")" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label asp-for="Currency" class="form-label">@T("Admin_Settings_Currency")</label>
                <input asp-for="Currency" class="form-control" placeholder="@T("Admin_Settings_CurrencyPlaceholder")" />
                <span asp-validation-for="Currency" class="text-danger small"></span>
            </div>

            <div class="form-group" style="grid-column:1/-1;">
                <label asp-for="Address" class="form-label">@T("Admin_Settings_Address")</label>
                <input asp-for="Address" class="form-control" placeholder="@T("Admin_Settings_AddressPlaceholder")" />
                <span asp-validation-for="Address" class="text-danger small"></span>
            </div>

            <div class="form-group" style="grid-column:1/-1;">
                <label asp-for="OpeningHours" class="form-label">@T("Admin_Settings_OpeningHours")</label>
                <textarea asp-for="OpeningHours" class="form-control" rows="3" placeholder="@T("Admin_Settings_OpeningHoursPlaceholder")"></textarea>
                <span asp-validation-for="OpeningHours" class="text-danger small"></span>
            </div>

            <div class="form-group" style="grid-column:1/-1;">
                <label asp-for="GoogleMapsUrl" class="form-label">@T("Admin_Settings_GoogleMapsUrl")</label>
                <input asp-for="GoogleMapsUrl" class="form-control" placeholder="@T("Admin_Settings_GoogleMapsUrlPlaceholder")" />
                <span asp-validation-for="GoogleMapsUrl" class="text-danger small"></span>
            </div>
        </div>

        <div style="display:flex;gap:1rem;justify-content:flex-end;margin-top:1rem;">
            <button type="submit" class="btn-submit">
                <i class="fas fa-save"></i>
                @T("Admin_SaveSettings")
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
