@model StoreSettingsViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Store Settings";
}

<h2 style="margin-bottom:2rem;font-size:1.5rem;font-weight:700;">
    <i class="fas fa-cog" style="color:var(--primary);margin-right:.5rem;"></i>
    Store Settings
</h2>

<div style="background:var(--surface);border-radius:var(--radius-lg);border:1px solid var(--border);padding:2.5rem;max-width:680px;">
    <form asp-action="Settings" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:1rem;"></div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;">
            <div class="form-group" style="grid-column:1/-1;">
                <label asp-for="StoreName" class="form-label"></label>
                <input asp-for="StoreName" class="form-control" placeholder="e.g. Fresh Grocery Store" />
                <span asp-validation-for="StoreName" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label asp-for="Phone" class="form-label"></label>
                <input asp-for="Phone" class="form-control" placeholder="+964 750 ..." />
                <span asp-validation-for="Phone" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label asp-for="WhatsappNumber" class="form-label"></label>
                <input asp-for="WhatsappNumber" class="form-control" placeholder="+9647501234567" />
                <span asp-validation-for="WhatsappNumber" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" placeholder="info@store.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label asp-for="Currency" class="form-label"></label>
                <input asp-for="Currency" class="form-control" placeholder="USD" />
                <span asp-validation-for="Currency" class="text-danger small"></span>
            </div>

            <div class="form-group" style="grid-column:1/-1;">
                <label asp-for="Address" class="form-label"></label>
                <input asp-for="Address" class="form-control" placeholder="City, Country" />
                <span asp-validation-for="Address" class="text-danger small"></span>
            </div>

            <div class="form-group" style="grid-column:1/-1;">
                <label asp-for="OpeningHours" class="form-label"></label>
                <textarea asp-for="OpeningHours" class="form-control" rows="3" placeholder="Sat – Thu: 8:00 AM – 10:00 PM&#10;Fri: 9:00 AM – 11:00 PM"></textarea>
                <span asp-validation-for="OpeningHours" class="text-danger small"></span>
            </div>

            <div class="form-group" style="grid-column:1/-1;">
                <label asp-for="GoogleMapsUrl" class="form-label"></label>
                <input asp-for="GoogleMapsUrl" class="form-control" placeholder="https://www.google.com/maps/embed?..." />
                <span asp-validation-for="GoogleMapsUrl" class="text-danger small"></span>
            </div>
        </div>

        <div style="display:flex;gap:1rem;justify-content:flex-end;margin-top:1rem;">
            <button type="submit" class="btn-submit">
                <i class="fas fa-save"></i>
                Save Settings
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
