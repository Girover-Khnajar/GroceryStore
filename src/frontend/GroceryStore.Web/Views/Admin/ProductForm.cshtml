@using GroceryStore.Domain.Enums
@model ProductFormViewModel
@using System.Globalization
@using System.Resources
@{
    Layout = "_AdminLayout";
    var sharedResourceManager = new ResourceManager("GroceryStore.Web.Shared.SharedResource", typeof(GroceryStore.Web.Controllers.HomeController).Assembly);
    string T(string key) => sharedResourceManager.GetString(key, CultureInfo.CurrentUICulture) ?? key;
    var isEdit = Model.Id.HasValue;
    ViewData["Title"] = isEdit ? T("Admin_EditProduct") : T("Admin_AddProduct");
}

<div class="form-card" style="max-width:720px;">
    <form asp-action="@(isEdit ? "ProductEdit" : "ProductCreate")"
          asp-route-id="@Model.Id"
          method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" style="color:var(--danger);margin-bottom:1rem;"></div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="Name" class="form-label">@T("Lbl_Name")</label>
                <input asp-for="Name" class="form-control" placeholder="e.g. Fresh Tomatoes" />
                <span asp-validation-for="Name" class="validation-message"></span>
            </div>
            <div class="form-group">
                <label asp-for="Slug" class="form-label">@T("Admin_Slug")</label>
                <input asp-for="Slug" class="form-control" placeholder="fresh-tomatoes" />
                <span asp-validation-for="Slug" class="validation-message"></span>
            </div>
        </div>

        <div class="form-group">
                <label asp-for="CategoryId" class="form-label">@T("Admin_Category")</label>
            <select asp-for="CategoryId" class="form-control">
                    <option value="">— @T("Admin_SelectCategory") —</option>
                @foreach (var c in Model.AvailableCategories)
                {
                    <option value="@c.Id">@c.Name</option>
                }
            </select>
            <span asp-validation-for="CategoryId" class="validation-message"></span>
        </div>

        <div class="form-row" style="grid-template-columns:1fr 1fr 1fr;">
            <div class="form-group">
                <label asp-for="PriceAmount" class="form-label">@T("Lbl_Price")</label>
                <input asp-for="PriceAmount" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="PriceAmount" class="validation-message"></span>
            </div>
            <div class="form-group">
                <label asp-for="PriceCurrency" class="form-label">@T("Admin_Currency")</label>
                <select asp-for="PriceCurrency" class="form-control">
                    @foreach (var currency in Model.AvailableCurrencies)
                    {
                        <option value="@currency">@currency</option>
                    }
                </select>
                <span asp-validation-for="PriceCurrency" class="validation-message"></span>
            </div>
            <div class="form-group">
                <label asp-for="Unit" class="form-label">@T("Admin_Unit")</label>
                <select asp-for="Unit" class="form-control">
                    @foreach (var unit in Enum.GetValues<ProductUnit>())
                    {
                        <option value="@unit">@unit</option>
                    }
                </select>
                <span asp-validation-for="Unit" class="validation-message"></span>
            </div>
        </div>

        <div class="form-group" style="margin-top:-.25rem;">
            <small style="color:var(--text-light);">
                @T("Admin_PricePreview") <strong id="pricePreview">@Model.PriceAmount.ToString("0.00") @Model.PriceCurrency / @Model.Unit</strong>
            </small>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="SortOrder" class="form-label">@T("Admin_SortOrder")</label>
                <input asp-for="SortOrder" type="number" class="form-control" />
            </div>
            <div class="form-group" style="display:flex;align-items:center;padding-top:1.5rem;gap:.5rem;">
                <input asp-for="IsFeatured" type="checkbox" />
                <label asp-for="IsFeatured" style="font-weight:500;">@T("Badge_Featured")</label>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="ShortDescription" class="form-label">@T("Admin_ShortDescription")</label>
            <textarea asp-for="ShortDescription" class="form-control" rows="2"></textarea>
        </div>

        <div class="form-group">
            <label asp-for="LongDescription" class="form-label">@T("Admin_LongDescription")</label>
            <textarea asp-for="LongDescription" class="form-control" rows="4"></textarea>
        </div>

        <hr style="border:none;border-top:1px solid var(--border);margin:1.5rem 0;" />
        <h4 style="font-size:1rem;font-weight:700;margin-bottom:1rem;">@T("Admin_SEO")</h4>

        <div class="form-group">
            <label asp-for="SeoMetaTitle" class="form-label">@T("Admin_MetaTitle")</label>
            <input asp-for="SeoMetaTitle" class="form-control" />
        </div>
        <div class="form-group">
            <label asp-for="SeoMetaDescription" class="form-label">@T("Admin_MetaDescription")</label>
            <textarea asp-for="SeoMetaDescription" class="form-control" rows="2"></textarea>
        </div>

        <div style="display:flex;gap:1rem;justify-content:flex-end;margin-top:1.5rem;">
            <a asp-action="Products" class="btn-secondary"><i class="fas fa-times"></i> @T("Btn_Cancel")</a>
            <button type="submit" class="btn-submit"><i class="fas fa-save"></i> @T("Btn_Save")</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const amountInput = document.getElementById('PriceAmount');
            const currencyInput = document.getElementById('PriceCurrency');
            const unitInput = document.getElementById('Unit');
            const preview = document.getElementById('pricePreview');

            if (!amountInput || !currencyInput || !unitInput || !preview) return;

            const updatePreview = () => {
                const rawAmount = parseFloat(amountInput.value);
                const amount = Number.isFinite(rawAmount) ? rawAmount.toFixed(2) : '0.00';
                const currency = (currencyInput.value || '').trim().toUpperCase();
                const unit = (unitInput.value || '').trim();
                preview.textContent = `${amount} ${currency} / ${unit}`.trim();
            };

            amountInput.addEventListener('input', updatePreview);
            currencyInput.addEventListener('change', updatePreview);
            unitInput.addEventListener('change', updatePreview);
            updatePreview();
        })();

        // ── Slug auto-generation ──────────────────────────────────────────
        (function () {
            const nameInput = document.getElementById('Name');
            const slugInput = document.getElementById('Slug');

            if (!nameInput || !slugInput) return;

            const toSlug = (text) =>
                text
                    .toLowerCase()
                    .normalize('NFD').replace(/[\u0300-\u036f]/g, '')   // strip accents
                    .replace(/[^a-z0-9\s-]/g, '')                       // keep alphanumeric
                    .trim()
                    .replace(/\s+/g, '-')                               // spaces → hyphens
                    .replace(/-{2,}/g, '-');                            // collapse multiple hyphens

            // Only auto-fill when the slug hasn't been manually edited
            let userEditedSlug = slugInput.value.length > 0 && slugInput.value !== toSlug(nameInput.value);

            slugInput.addEventListener('input', () => {
                userEditedSlug = true;
            });

            nameInput.addEventListener('input', () => {
                if (!userEditedSlug) {
                    slugInput.value = toSlug(nameInput.value);
                }
            });
        })();
    </script>
}
