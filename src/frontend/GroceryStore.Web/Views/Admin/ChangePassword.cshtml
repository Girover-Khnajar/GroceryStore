@model GroceryStore.Web.ViewModels.Admin.ChangePasswordViewModel
@using System.Globalization
@using System.Resources
@{
    Layout = "_AdminLayout";
    var sharedResourceManager = new ResourceManager("GroceryStore.Web.Shared.SharedResource", typeof(GroceryStore.Web.Controllers.HomeController).Assembly);
    string T(string key) => sharedResourceManager.GetString(key, CultureInfo.CurrentUICulture) ?? key;
    ViewData["Title"] = T("Admin_ChangePassword");
}

<h2 style="margin-bottom:2rem;font-size:1.5rem;font-weight:700;">
    <i class="fas fa-key" style="color:var(--primary);margin-right:.5rem;"></i>
    @T("Admin_ChangePassword")
</h2>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success" style="margin-bottom:1.5rem;">
        <i class="fas fa-check-circle"></i> @success
    </div>
}

<div style="background:var(--surface);border-radius:var(--radius-lg);border:1px solid var(--border);padding:2.5rem;max-width:480px;">
    <form asp-action="ChangePassword" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:1rem;"></div>

        <div class="form-group">
            <label asp-for="CurrentPassword" class="form-label">@T("Admin_CurrentPassword")</label>
            <input asp-for="CurrentPassword" type="password" class="form-control"
                   placeholder="@T("Admin_CurrentPasswordPlaceholder")"
                   autocomplete="current-password" />
            <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
        </div>

        <div class="form-group">
            <label asp-for="NewPassword" class="form-label">@T("Admin_NewPassword")</label>
            <input asp-for="NewPassword" type="password" class="form-control"
                   placeholder="@T("Admin_NewPasswordPlaceholder")"
                   autocomplete="new-password" />
            <span asp-validation-for="NewPassword" class="text-danger small"></span>
        </div>

        <div class="form-group">
            <label asp-for="ConfirmPassword" class="form-label">@T("Admin_ConfirmPassword")</label>
            <input asp-for="ConfirmPassword" type="password" class="form-control"
                   placeholder="@T("Admin_ConfirmPasswordPlaceholder")"
                   autocomplete="new-password" />
            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
        </div>

        <button type="submit" class="btn btn-primary" style="margin-top:.5rem;">
            <i class="fas fa-save"></i> @T("Admin_SavePassword")
        </button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
