@model IReadOnlyList<GroceryStore.Application.Categories.Dtos.CategoryDto>
@using System.Globalization
@using System.Resources
@{
    Layout = "_AdminLayout";
    var sharedResourceManager = new ResourceManager("GroceryStore.Web.Shared.SharedResource", typeof(GroceryStore.Web.Controllers.HomeController).Assembly);
    string T(string key) => sharedResourceManager.GetString(key, CultureInfo.CurrentUICulture) ?? key;
    ViewData["Title"] = T("Admin_ManageCategories");
}

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;flex-wrap:wrap;gap:1rem;">
    <h2 style="font-size:1.25rem;font-weight:700;"><i class="fas fa-th-large" style="color:var(--primary);"></i> @T("Nav_Categories")</h2>
    <a asp-action="CategoryCreate" class="btn btn-primary"><i class="fas fa-plus"></i> @T("Admin_AddCategory")</a>
</div>

<div class="table-wrapper">
    <table class="admin-table">
        <thead>
            <tr>
                <th style="width:60px;">Image</th>
                <th>@T("Lbl_Name")</th>
                <th>Slug</th>
                <th style="text-align:center;">@T("Admin_Order")</th>
                <th style="text-align:center;">@T("Admin_Active")</th>
                <th style="text-align:center;">@T("Admin_Actions")</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="6" style="text-align:center;padding:2rem;color:var(--text-light);">
                        @T("Admin_NoCategoriesYet")
                    </td>
                </tr>
            }
            @foreach (var c in Model)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(c.ImageUrl))
                        {
                            <img src="@c.ImageUrl" alt="@c.Name"
                                style="width:40px;height:40px;border-radius:var(--radius-sm);object-fit:cover;" />
                        }
                        else
                        {
                            <div style="width:40px;height:40px;border-radius:var(--radius-sm);background:var(--surface-alt);display:flex;align-items:center;justify-content:center;">
                                <i class="fas fa-image" style="color:var(--text-light);font-size:.75rem;"></i>
                            </div>
                        }
                    </td>
                    <td><strong>@c.Name</strong></td>
                    <td style="color:var(--text-light);font-size:.85rem;">@c.Slug</td>
                    <td style="text-align:center;">@c.SortOrder</td>
                    <td style="text-align:center;">
                        @if (c.IsActive)
                        {
                            <i class="fas fa-check-circle" style="color:#059669;"></i>
                        }
                        else
                        {
                            <i class="fas fa-times-circle" style="color:#dc2626;"></i>
                        }
                    </td>
                    <td style="text-align:center;white-space:nowrap;">
                        <a asp-action="CategoryEdit" asp-route-id="@c.Id" class="btn-edit" title="@T("Btn_Edit")">
                            <i class="fas fa-edit"></i>
                        </a>
                        <form asp-action="CategoryDelete" asp-route-id="@c.Id" method="post"
                              style="display:inline;"
                              onsubmit="return confirm('@T("Admin_DeleteCategoryConfirm")');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-delete" title="@T("Btn_Delete")">
                                <i class="fas fa-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
