@model CategoryFormViewModel
@using System.Globalization
@using System.Resources
@{
    Layout = "_AdminLayout";
    var sharedResourceManager = new ResourceManager("GroceryStore.Web.Shared.SharedResource", typeof(GroceryStore.Web.Controllers.HomeController).Assembly);
    string T(string key) => sharedResourceManager.GetString(key, CultureInfo.CurrentUICulture) ?? key;
    var isEdit = Model.Id.HasValue;
    ViewData["Title"] = isEdit ? T("Admin_EditCategory") : T("Admin_AddCategory");
}

<div class="form-card" style="max-width:640px;">
    <form asp-action="@(isEdit ? "CategoryEdit" : "CategoryCreate")"
          asp-route-id="@Model.Id"
          method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" style="color:var(--danger);margin-bottom:1rem;"></div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="Name" class="form-label">@T("Lbl_Name")</label>
                <input asp-for="Name" class="form-control" placeholder="e.g. Fresh Vegetables" />
                <span asp-validation-for="Name" class="validation-message"></span>
            </div>
            <div class="form-group">
                <label asp-for="Slug" class="form-label">@T("Admin_Slug")</label>
                <input asp-for="Slug" class="form-control" placeholder="fresh-vegetables" />
                <span asp-validation-for="Slug" class="validation-message"></span>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="ParentCategoryId" class="form-label">@T("Admin_ParentCategory")</label>
            <select asp-for="ParentCategoryId" class="form-control">
                <option value="">— @T("Admin_NoneRoot") —</option>
                @foreach (var p in Model.AvailableParents.Where(c => c.Id != Model.Id))
                {
                    <option value="@p.Id">@p.Name</option>
                }
            </select>
        </div>

        <div class="form-group">
            <label asp-for="Description" class="form-label">@T("Lbl_Description")</label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="ImageUrl" class="form-label">@T("Admin_ImageUrl")</label>
                <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
            </div>
            <div class="form-group">
                <label asp-for="IconName" class="form-label">@T("Admin_Icon")</label>
                <input asp-for="IconName" class="form-control" placeholder="fas fa-carrot" />
            </div>
        </div>

        <div class="form-group" style="max-width:200px;">
            <label asp-for="SortOrder" class="form-label">@T("Admin_SortOrder")</label>
            <input asp-for="SortOrder" type="number" class="form-control" />
        </div>

        <hr style="border:none;border-top:1px solid var(--border);margin:1.5rem 0;" />
        <h4 style="font-size:1rem;font-weight:700;margin-bottom:1rem;">@T("Admin_SEO")</h4>

        <div class="form-group">
            <label asp-for="SeoMetaTitle" class="form-label">@T("Admin_MetaTitle")</label>
            <input asp-for="SeoMetaTitle" class="form-control" />
        </div>
        <div class="form-group">
            <label asp-for="SeoMetaDescription" class="form-label">@T("Admin_MetaDescription")</label>
            <textarea asp-for="SeoMetaDescription" class="form-control" rows="2"></textarea>
        </div>

        <div style="display:flex;gap:1rem;justify-content:flex-end;margin-top:1.5rem;">
            <a asp-action="Categories" class="btn-secondary"><i class="fas fa-times"></i> @T("Btn_Cancel")</a>
            <button type="submit" class="btn-submit"><i class="fas fa-save"></i> @T("Btn_Save")</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const nameInput = document.getElementById('Name');
            const slugInput = document.getElementById('Slug');

            if (!nameInput || !slugInput) return;

            const toSlug = (text) =>
                text
                    .toLowerCase()
                    .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
                    .replace(/[^a-z0-9\s-]/g, '')
                    .trim()
                    .replace(/\s+/g, '-')
                    .replace(/-{2,}/g, '-');

            let userEditedSlug = slugInput.value.length > 0 && slugInput.value !== toSlug(nameInput.value);

            slugInput.addEventListener('input', () => {
                userEditedSlug = true;
            });

            nameInput.addEventListener('input', () => {
                if (!userEditedSlug) {
                    slugInput.value = toSlug(nameInput.value);
                }
            });
        })();
    </script>
}
