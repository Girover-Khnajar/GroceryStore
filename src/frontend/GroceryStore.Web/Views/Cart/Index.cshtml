@model GroceryStore.Web.ViewModels.Cart.CartPageViewModel
@{
    ViewData["Title"] = "Shopping Cart";
}

<section class="section cart-page" style="padding-top: calc(var(--nav-height) + 2rem);">
    <div class="container">
        <h1 class="section-title cart-page-title" style="text-align:left;">Shopping Cart</h1>

        @if (Model.Items.Count == 0)
        {
            <div class="empty-state">
                <i class="fas fa-shopping-cart" style="font-size:3rem;color:var(--border);margin-bottom:1rem;"></i>
                <h3>Your cart is empty</h3>
                <p>Add products to continue.</p>
                <a asp-controller="Products" asp-action="Index" class="btn btn-primary" style="margin-top:1rem;">
                    <i class="fas fa-box-open"></i> Browse Products
                </a>
            </div>
        }
        else
        {
            <div class="table-wrapper cart-table-wrapper" style="margin-top:1rem;">
                <table class="admin-table cart-table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Price</th>
                            <th style="width:160px;">Quantity</th>
                            <th>Subtotal</th>
                            <th style="text-align:center;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td data-label="Product" class="cart-product-cell">
                                    <a asp-controller="Products" asp-action="Details" asp-route-slug="@item.Slug">
                                        <strong>@item.Name</strong>
                                    </a>
                                    @if (!string.IsNullOrWhiteSpace(item.Brand))
                                    {
                                        <div class="cart-product-meta">@item.Brand</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(item.Sku))
                                    {
                                        <div class="cart-product-meta">SKU: @item.Sku</div>
                                    }
                                </td>
                                <td data-label="Price">@item.UnitPrice.ToString("N2") @item.Currency / @item.Unit</td>
                                <td data-label="Quantity">
                                    <form asp-action="Update" method="post" class="cart-qty-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <button type="button" class="btn-qty-decrement" onclick="decrementQuantity(this, '@item.ProductId')" title="Decrease quantity">
                                            <i class="fas fa-minus"></i>
                                        </button>
                                        <input type="number" name="quantity" value="@item.Quantity" min="1" class="form-control qty-input cart-qty-input" />
                                        <button type="button" class="btn-qty-increment" onclick="incrementQuantity(this, '@item.ProductId')" title="Increase quantity">
                                            <i class="fas fa-plus"></i>
                                        </button>
                                        <button type="submit" class="btn btn-primary btn-sm cart-update-btn">Update</button>
                                    </form>
                                </td>
                                <td data-label="Subtotal" class="cart-subtotal-cell">@item.LineTotal.ToString("N2") @item.Currency</td>
                                <td data-label="Actions" class="cart-actions-cell">
                                    <form asp-action="Remove" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <button type="submit" class="btn-delete" title="Remove">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="cart-summary">
                <h3 class="cart-summary-title">Order Summary</h3>
                
                @{
                    var groupedByCurrency = Model.Items.GroupBy(x => x.Currency).OrderBy(g => g.Key);
                }
                
                @foreach (var currencyGroup in groupedByCurrency)
                {
                    var total = currencyGroup.Sum(x => x.LineTotal);
                    <div class="cart-summary-row">
                        <span>Total (@currencyGroup.Key):</span>
                        <strong>@total.ToString("N2") @currencyGroup.Key</strong>
                    </div>
                }
                
                @if (groupedByCurrency.Count() > 1)
                {
                    <div class="cart-summary-note">
                        <em>Note: Multiple currencies in cart. Please review each total before checkout.</em>
                    </div>
                }
            </div>

            <div class="cart-footer-actions">
                <form asp-action="Clear" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-secondary cart-clear-btn" onclick="return confirm('Clear all items from cart?');">
                        <i class="fas fa-times"></i> Clear Cart
                    </button>
                </form>

                <a asp-action="Checkout" class="btn btn-primary cart-checkout-btn">
                    <i class="fab fa-whatsapp"></i> Checkout & Send to WhatsApp
                </a>
            </div>
        }
    </div>
</section>
