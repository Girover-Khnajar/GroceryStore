@model GroceryStore.Web.ViewModels.ContactViewModel
@using System.Globalization
@using System.Resources
@{
    var viewResourceManager = new ResourceManager("GroceryStore.Web.Resources.Views.Home_Contact", typeof(GroceryStore.Web.Controllers.HomeController).Assembly);
    string T(string key) => viewResourceManager.GetString(key, CultureInfo.CurrentUICulture) ?? key;
    ViewData["Title"] = T("PageTitle");
}

<section class="section" style="padding-top: calc(var(--nav-height) + 2rem);">
    <div class="container">

        <h1 class="section-title">@T("SectionTitle")</h1>
        <p style="text-align:center;color:var(--text-light);max-width:600px;margin:0 auto 3rem;">
            @T("SectionSubtitle")
        </p>

        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1.5rem;margin-bottom:3rem;">

            @if (!string.IsNullOrWhiteSpace(Model.Phone))
            {
                <div class="contact-card" style="background:var(--surface);border-radius:var(--radius-lg);padding:2rem;text-align:center;border:1px solid var(--border);">
                    <i class="fas fa-phone" style="font-size:2.5rem;color:var(--primary);margin-bottom:1rem;"></i>
                    <h3 style="margin-bottom:.5rem;">@T("Card_Phone")</h3>
                    <a href="tel:@Model.Phone" style="color:var(--text-light);">@Model.Phone</a>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.WhatsappNumber))
            {
                <div class="contact-card" style="background:var(--surface);border-radius:var(--radius-lg);padding:2rem;text-align:center;border:1px solid var(--border);">
                    <i class="fab fa-whatsapp" style="font-size:2.5rem;color:#25d366;margin-bottom:1rem;"></i>
                    <h3 style="margin-bottom:.5rem;">@T("Card_WhatsApp")</h3>
                    <a href="https://wa.me/@Model.WhatsappNumber" style="color:var(--text-light);" target="_blank" rel="noopener">@T("Link_MessageUs")</a>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.Email))
            {
                <div class="contact-card" style="background:var(--surface);border-radius:var(--radius-lg);padding:2rem;text-align:center;border:1px solid var(--border);">
                    <i class="fas fa-envelope" style="font-size:2.5rem;color:var(--primary);margin-bottom:1rem;"></i>
                    <h3 style="margin-bottom:.5rem;">@T("Card_Email")</h3>
                    <a href="mailto:@Model.Email" style="color:var(--text-light);">@Model.Email</a>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.Address))
            {
                <div class="contact-card" style="background:var(--surface);border-radius:var(--radius-lg);padding:2rem;text-align:center;border:1px solid var(--border);">
                    <i class="fas fa-map-marker-alt" style="font-size:2.5rem;color:var(--primary);margin-bottom:1rem;"></i>
                    <h3 style="margin-bottom:.5rem;">@T("Card_Address")</h3>
                    <p style="color:var(--text-light);">@Model.Address</p>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.OpeningHours))
            {
                <div class="contact-card" style="background:var(--surface);border-radius:var(--radius-lg);padding:2rem;text-align:center;border:1px solid var(--border);">
                    <i class="fas fa-clock" style="font-size:2.5rem;color:var(--primary);margin-bottom:1rem;"></i>
                    <h3 style="margin-bottom:.5rem;">@T("Card_OpeningHours")</h3>
                    @foreach (var line in Model.OpeningHours.Split('\n', StringSplitOptions.RemoveEmptyEntries))
                    {
                        <p style="color:var(--text-light);font-size:.9rem;">@line</p>
                    }
                </div>
            }

        </div>

        @if (!string.IsNullOrWhiteSpace(Model.GoogleMapsUrl))
        {
            <div style="border-radius:var(--radius-lg);overflow:hidden;border:2px solid var(--border);">
                <iframe src="@Model.GoogleMapsUrl"
                        width="100%" height="420" style="border:0;" allowfullscreen
                        loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>
        }

    </div>
</section>
