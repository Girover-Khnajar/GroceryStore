@model HomeViewModel
@using System.Globalization
@using System.Resources
@{
    var viewResourceManager = new ResourceManager("GroceryStore.Web.Resources.Views.Home_Index", typeof(GroceryStore.Web.Controllers.HomeController).Assembly);
    string T(string key) => viewResourceManager.GetString(key, CultureInfo.CurrentUICulture) ?? key;
    ViewData["Title"] = T("PageTitle");
}

@* ═══ Hero Section ═══ *@
<section class="hero">
    <div class="container">
        <div class="hero-content">
            <h1 class="hero-title">@T("HeroTitlePrefix") <span class="highlight">@T("HeroTitleHighlight")</span></h1>
            <p class="hero-subtitle">@T("HeroSubtitle")</p>
            <div class="hero-actions">
                <a asp-controller="Products" asp-action="Index" class="btn btn-primary">
                    <i class="fas fa-shopping-cart"></i> @T("Btn_ShopNow")
                </a>
                <a asp-controller="Categories" asp-action="Index" class="btn btn-outline">
                    <i class="fas fa-th-large"></i> @T("Btn_BrowseCategories")
                </a>
            </div>
        </div>
    </div>
</section>

@* ═══ Categories ═══ *@
@if (Model.Categories.Count > 0)
{
    <section class="section">
        <div class="container">
            <h2 class="section-title">@T("Section_ShopByCategory")</h2>
            <div class="categories-grid">
                @foreach (var cat in Model.Categories.Take(5))
                {
                    var categoryImage = !string.IsNullOrWhiteSpace(cat.ImageUrl)
                        ? cat.ImageUrl!
                        : $"https://picsum.photos/seed/category-{Uri.EscapeDataString(cat.Slug)}/900/675";

                    <a asp-controller="Categories" asp-action="Details" asp-route-slug="@cat.Slug"
                       class="category-card">
                        <div class="category-image">
                            <img src="@categoryImage" alt="@cat.Name" />
                        </div>
                        <div class="category-info">
                            <h3>@cat.Name</h3>
                        </div>
                    </a>
                }
            </div>
            <div style="text-align:center; margin-top:2rem;">
                <a asp-controller="Categories" asp-action="Index" class="btn btn-outline">
                    @T("Btn_AllCategories") <i class="fas fa-arrow-right"></i>
                </a>
            </div>
        </div>
    </section>
}

@* ═══ Featured Products ═══ *@
@if (Model.FeaturedProducts.Count > 0)
{
    <section class="section section-alt">
        <div class="container">
            <h2 class="section-title">@T("Section_FeaturedProducts")</h2>
            <div class="products-grid">
                @foreach (var p in Model.FeaturedProducts.Take(6))
                {
                    var productImage = $"https://picsum.photos/seed/{Uri.EscapeDataString(p.Slug)}/900/900";

                    <a asp-controller="Products" asp-action="Details" asp-route-slug="@p.Slug"
                       class="product-card">
                        <div class="product-image">
                            <img src="@productImage" alt="@p.Name" loading="lazy" />
                            @if (p.IsFeatured)
                            {
                                <span class="badge-featured"><i class="fas fa-star"></i> @T("Badge_Featured")</span>
                            }
                        </div>
                        <div class="product-info">
                            <div class="product-name">@p.Name</div>
                            @if (!string.IsNullOrWhiteSpace(p.Brand))
                            {
                                <div class="product-category">@p.Brand</div>
                            }
                            <div class="product-footer">
                                <span class="product-price">
                                    @p.PriceAmount.ToString("N2") @p.PriceCurrency
                                    @if (!string.IsNullOrWhiteSpace(p.Unit))
                                    {
                                        <span style="color:var(--text-light);font-size:.85rem;">/ @p.Unit</span>
                                    }
                                </span>
                                <button type="button" class="btn-whatsapp" onclick="addToCart(event, '@p.Id')" title="@T("Title_AddToCart")">
                                    <i class="fas fa-cart-plus"></i>
                                </button>
                            </div>
                        </div>
                    </a>
                }
            </div>
            <div style="text-align:center; margin-top:2rem;">
                <a asp-controller="Products" asp-action="Index" class="btn btn-primary">
                    <i class="fas fa-box-open"></i> @T("Btn_AllProducts")
                </a>
            </div>
        </div>
    </section>
}
