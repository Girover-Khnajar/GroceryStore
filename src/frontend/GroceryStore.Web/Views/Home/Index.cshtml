@model HomeViewModel
@using System.Globalization
@using System.Resources
@inject GroceryStore.Web.Services.ImageUrlHelper ImageHelper
@{
    var viewResourceManager = new ResourceManager("GroceryStore.Web.Resources.Views.Home_Index", typeof(GroceryStore.Web.Controllers.HomeController).Assembly);
    string T(string key) => viewResourceManager.GetString(key, CultureInfo.CurrentUICulture) ?? key;
    ViewData["Title"] = T("PageTitle");
    ViewData["MetaDescription"] = T("Home_MetaDescription");
    ViewData["OgImage"] = Url.Content("~/images/ui/hero-1.jpeg");
    var seoBaseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}";

    // Hero carousel slides — swap src for your 3 real images when ready
    var heroSlides = new[]
    {
        new { Src = Url.Content("~/images/ui/hero-1.jpeg"), Alt = "Fresh grocery store interior" },
        new { Src = Url.Content("~/images/ui/hero-2.jpeg"), Alt = "Fresh fruits and vegetables" },
        new { Src = Url.Content("~/images/ui/hero-3.jpeg"), Alt = "Quality grocery products" },
    };

    // Features strip
    var features = new[]
    {
        new { Icon = "fas fa-leaf",          Title = T("Feature_Fresh"),    Desc = T("Feature_FreshDesc")   },
        new { Icon = "fas fa-shield-alt",    Title = T("Feature_Quality"),  Desc = T("Feature_QualityDesc") },
        new { Icon = "fas fa-tag",           Title = T("Feature_Prices"),   Desc = T("Feature_PricesDesc")  },
        new { Icon = "fas fa-shipping-fast", Title = T("Feature_Delivery"), Desc = T("Feature_DeliveryDesc")},
    };
}

@* ═══ Hero Carousel ═══ *@
<section class="hero-carousel" id="heroCarousel">
    @for (int i = 0; i < heroSlides.Length; i++)
    {
        <div class="hero-slide @(i == 0 ? "active" : "")" style="background-image:url(@heroSlides[i].Src)" aria-label="@heroSlides[i].Alt">
            <div class="hero-overlay"></div>
        </div>
    }

    @* Text content on top *@
    <div class="hero-body">
        <div class="container">
            <div class="hero-content">
                <h1 class="hero-title">
                    @T("HeroTitlePrefix")
                    <span class="hero-highlight">@T("HeroTitleHighlight")</span>
                </h1>
                <p class="hero-subtitle">@T("HeroSubtitle")</p>
                <div class="hero-actions">
                    <a asp-controller="Products" asp-action="Index" class="btn btn-hero-primary">
                        <i class="fas fa-shopping-cart"></i> @T("Btn_ShopNow")
                    </a>
                    <a asp-controller="Categories" asp-action="Index" class="btn btn-hero-outline">
                        <i class="fas fa-th-large"></i> @T("Btn_BrowseCategories")
                    </a>
                </div>
            </div>
        </div>
    </div>

    @* Dot indicators *@
    <div class="hero-dots">
        @for (int i = 0; i < heroSlides.Length; i++)
        {
            <button class="hero-dot @(i == 0 ? "active" : "")" data-slide="@i" onclick="HeroCarousel.goTo(@i)" aria-label="Slide @(i+1)"></button>
        }
    </div>
</section>

@* ═══ Shop by Category ═══ *@
@if (Model.Categories.Count > 0)
{
    <section class="section home-categories">
        <div class="container">
            <h2 class="section-title">@T("Section_ShopByCategory")</h2>
            <div class="home-categories-grid">
                @foreach (var cat in Model.Categories.Take(6))
                {
                    var thumbUrl = ImageHelper.GetThumbnailUrl(cat.ImageUrl);
                    <a asp-controller="Categories" asp-action="Details" asp-route-slug="@cat.Slug" class="home-cat-card">
                        @await Html.PartialAsync("_OptimizedImage", new OptimizedImageModel {
                            Src = cat.ImageUrl,
                            ThumbnailSrc = thumbUrl,
                            Alt = cat.Name,
                            ContainerClass = "home-cat-img",
                            AspectRatio = "4/3",
                            Eager = false,
                            Fallback = "/images/ui/no-thumbnail.svg"
                        })
                        <div class="home-cat-body">
                            <span class="home-cat-name">@cat.Name</span>
                            <span class="home-cat-arrow"><i class="fas fa-arrow-right"></i></span>
                        </div>
                    </a>
                }
            </div>
        </div>
    </section>
}

@* ═══ Features Strip ═══ *@
<section class="home-features">
    <div class="container">
        <div class="home-features-grid">
            @foreach (var f in features)
            {
                <div class="home-feature-item">
                    <div class="home-feature-icon">
                        <i class="@f.Icon"></i>
                    </div>
                    <div class="home-feature-text">
                        <strong>@f.Title</strong>
                        <span>@f.Desc</span>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

@* ═══ Featured Products ═══ *@
@if (Model.FeaturedProducts.Count > 0)
{
    <section class="section home-products">
        <div class="container">
            <h2 class="section-title">@T("Section_FeaturedProducts")</h2>
            <div class="products-grid">
                @foreach (var p in Model.FeaturedProducts.Take(6))
                {
                    var thumbUrl = ImageHelper.GetThumbnailUrl(p.PrimaryImageId);
                    var featOverlay = p.IsFeatured ? $"<span class=\"badge-featured\"><i class=\"fas fa-star\"></i> {T("Badge_Featured")}</span>" : null;
                    <a asp-controller="Products" asp-action="Details" asp-route-slug="@p.Slug" class="product-card">
                        @await Html.PartialAsync("_OptimizedImage", new OptimizedImageModel {
                            Src = p.PrimaryImageId,
                            ThumbnailSrc = thumbUrl,
                            Alt = p.Name,
                            ContainerClass = "product-image",
                            AspectRatio = "1/1",
                            Eager = false,
                            Fallback = "/images/ui/no-thumbnail.svg",
                            ShowOverlay = p.IsFeatured,
                            OverlayContent = featOverlay
                        })
                        <div class="product-info">
                            <div class="product-name">@p.Name</div>
                            @if (!string.IsNullOrWhiteSpace(p.Brand))
                            {
                                <div class="product-category">@p.Brand</div>
                            }
                            <div class="product-footer">
                                <span class="product-price">
                                    @p.PriceAmount.ToString("N2") @p.PriceCurrency
                                    @if (!string.IsNullOrWhiteSpace(p.Unit))
                                    {
                                        <span style="color:var(--text-light);font-size:.85rem;">/ @p.Unit</span>
                                    }
                                </span>
                                <button type="button" class="btn-whatsapp" onclick="addToCart(event, '@p.Id')" title="@T("Title_AddToCart")">
                                    <i class="fas fa-cart-plus"></i>
                                </button>
                            </div>
                        </div>
                    </a>
                }
            </div>
            <div style="text-align:center;margin-top:2rem;">
                <a asp-controller="Products" asp-action="Index" class="btn btn-primary">
                    <i class="fas fa-box-open"></i> @T("Btn_AllProducts")
                </a>
            </div>
        </div>
    </section>
}

@* ═══ Testimonials ═══ *@
@if (Model.Testimonials.Count > 0)
{
    <style>
        #testimonialsCarousel { position:relative; padding:0 44px; box-sizing:border-box; }
        #testimonialsCarousel .tc-btn {
            position:absolute; top:50%; transform:translateY(-50%);
            width:36px; height:36px; border:1px solid var(--border);
            background:var(--surface); border-radius:50%; cursor:pointer;
            z-index:1; display:flex; align-items:center; justify-content:center;
            color:var(--text);
        }
        #testimonialsCarousel .tc-btn-prev { left:0; }
        #testimonialsCarousel .tc-btn-next { right:0; }
        #testimonialsCarousel .tc-btn:hover { background:var(--bg-light); }
        #testimonialsCarousel .tc-viewport { overflow:hidden; }
        #testimonialsCarousel .tc-track { display:flex; flex-wrap:nowrap; }
        #testimonialsCarousel .tc-item {
            flex:0 0 auto;
            background:var(--surface); border:1px solid var(--border);
            border-radius:var(--radius-lg); padding:1rem;
            display:flex; flex-direction:column; gap:.75rem;
            box-sizing:border-box;
        }
        #testimonialsCarousel .tc-dots { display:flex; justify-content:center; gap:.4rem; margin-top:1rem; }
        #testimonialsCarousel .tc-dots button {
            width:10px; height:10px; border-radius:50%; border:none;
            cursor:pointer; padding:0; transition:background .25s;
        }
    </style>

    <section class="section" style="padding-top:1rem;">
        <div class="container">
            <h2 class="section-title">@T("Section_Testimonials")</h2>

            <div id="testimonialsCarousel">
                <button type="button" class="tc-btn tc-btn-prev" onclick="TestimonialsCarousel.prev()" aria-label="Previous testimonials">
                    <i class="fas fa-chevron-left"></i>
                </button>

                <div class="tc-viewport">
                    <div class="tc-track">
                        @foreach (var t in Model.Testimonials)
                        {
                            <div class="tc-item">
                                <div style="display:flex;align-items:center;gap:.75rem;">
                                    @if (!string.IsNullOrWhiteSpace(t.ClientImage))
                                    {
                                        <img src="@t.ClientImage" alt="@t.ClientName" style="width:52px;height:52px;border-radius:50%;object-fit:cover;border:1px solid var(--border);" loading="lazy" />
                                    }
                                    else
                                    {
                                        <div style="width:52px;height:52px;border-radius:50%;background:var(--bg-light);display:flex;align-items:center;justify-content:center;border:1px solid var(--border);">
                                            <i class="fas fa-user" style="color:var(--text-light);"></i>
                                        </div>
                                    }
                                    <div>
                                        <div style="font-weight:700;">@t.ClientName</div>
                                        @if (!string.IsNullOrWhiteSpace(t.ClientTitle) || !string.IsNullOrWhiteSpace(t.ClientCompany))
                                        {
                                            <div style="font-size:.85rem;color:var(--text-light);">
                                                @t.ClientTitle@if (!string.IsNullOrWhiteSpace(t.ClientTitle) && !string.IsNullOrWhiteSpace(t.ClientCompany)){<text>, </text>}@t.ClientCompany
                                            </div>
                                        }
                                    </div>
                                </div>

                                @if (t.Rating.HasValue)
                                {
                                    <div style="color:#f59e0b;font-size:.9rem;">
                                        @for (var i = 0; i < t.Rating.Value; i++)
                                        {
                                            <i class="fas fa-star"></i>
                                        }
                                    </div>
                                }

                                <blockquote style="margin:0;color:var(--text-light);font-style:italic;line-height:1.55;">
                                    "@t.Testimonial"
                                </blockquote>
                            </div>
                        }
                    </div>
                </div>

                <button type="button" class="tc-btn tc-btn-next" onclick="TestimonialsCarousel.next()" aria-label="Next testimonials">
                    <i class="fas fa-chevron-right"></i>
                </button>

                <div class="tc-dots"></div>
            </div>
        </div>
    </section>
}

@* ═══ Newsletter ═══ *@
<section class="home-newsletter">
    <div class="container">
        <div class="home-newsletter-inner">
            <div class="home-newsletter-img">
                <img src="/images/ui/basket.png" alt="Fresh basket"
                     onerror="this.style.display='none'" loading="lazy" />
            </div>
            <div class="home-newsletter-body">
                <h3>@T("Newsletter_Title")</h3>
                <p>@T("Newsletter_Sub")</p>
            </div>
            <form class="home-newsletter-form" onsubmit="return false;">
                <input type="email" placeholder="@T("Newsletter_Placeholder")" required />
                <button type="submit" class="btn btn-primary">@T("Newsletter_Btn")</button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
<script>
var HeroCarousel = (function () {
    var slides = document.querySelectorAll('.hero-slide');
    var dots   = document.querySelectorAll('.hero-dot');
    var current = 0;
    var timer;

    function goTo(idx) {
        slides[current].classList.remove('active');
        dots[current].classList.remove('active');
        current = (idx + slides.length) % slides.length;
        slides[current].classList.add('active');
        dots[current].classList.add('active');
        resetTimer();
    }

    function next() { goTo(current + 1); }

    function resetTimer() {
        clearInterval(timer);
        timer = setInterval(next, 5000);
    }

    document.addEventListener('DOMContentLoaded', function () {
        if (slides.length > 1) resetTimer();
    });

    return { goTo: goTo };
})();

var TestimonialsCarousel = (function () {
    var track, viewport, dotsEl, prevBtn, nextBtn;
    var items = [];
    var current = 0;
    var ipp = 1;       // items per page
    var pages = 0;
    var itemWidth = 0; // stored after layout so updatePosition stays consistent
    var gap = 0;
    var timer;

    function getIpp() { return window.innerWidth >= 768 ? 3 : 1; }

    function layout() {
        ipp = getIpp();
        gap = ipp > 1 ? 16 : 0;
        var vw = viewport.offsetWidth;
        itemWidth = Math.floor((vw - gap * (ipp - 1)) / ipp);

        items.forEach(function (item) {
            item.style.width = itemWidth + 'px';
            item.style.flexShrink = '0';
        });
        track.style.gap = gap + 'px';

        pages = Math.ceil(items.length / ipp);
        if (current >= pages) current = 0;

        buildDots();

        var show = pages > 1;
        prevBtn.style.display = show ? '' : 'none';
        nextBtn.style.display = show ? '' : 'none';

        updatePosition(false);
        if (show) resetTimer(); else clearInterval(timer);
    }

    function buildDots() {
        dotsEl.innerHTML = '';
        if (pages <= 1) return;
        for (var i = 0; i < pages; i++) {
            var btn = document.createElement('button');
            btn.type = 'button';
            btn.setAttribute('aria-label', 'Page ' + (i + 1));
            btn.style.background = i === current ? 'var(--primary)' : 'var(--border)';
            (function (idx) {
                btn.addEventListener('click', function () { goTo(idx); });
            }(i));
            dotsEl.appendChild(btn);
        }
    }

    function updateDots() {
        var btns = dotsEl.querySelectorAll('button');
        btns.forEach(function (b, i) {
            b.style.background = i === current ? 'var(--primary)' : 'var(--border)';
        });
    }

    function updatePosition(animate) {
        if (!items.length || itemWidth === 0) return;
        var offset = current * ipp * (itemWidth + gap);
        track.style.transition = animate ? 'transform .45s cubic-bezier(.4,0,.2,1)' : 'none';
        track.style.transform = 'translateX(-' + offset + 'px)';
        updateDots();
    }

    function goTo(index) {
        if (!track || pages === 0) return;
        current = (index + pages) % pages;
        updatePosition(true);
        resetTimer();
    }

    function next() { goTo(current + 1); }
    function prev() { goTo(current - 1); }

    function resetTimer() {
        clearInterval(timer);
        if (pages > 1) timer = setInterval(next, 7000);
    }

    var resizeTimer;
    window.addEventListener('resize', function () {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(function () {
            var newIpp = getIpp();
            if (newIpp !== ipp) current = 0;
            layout();
        }, 150);
    });

    document.addEventListener('DOMContentLoaded', function () {
        var carousel = document.getElementById('testimonialsCarousel');
        if (!carousel) return;
        track    = carousel.querySelector('.tc-track');
        viewport = carousel.querySelector('.tc-viewport');
        dotsEl   = carousel.querySelector('.tc-dots');
        prevBtn  = carousel.querySelector('.tc-btn-prev');
        nextBtn  = carousel.querySelector('.tc-btn-next');
        items    = Array.from(track.children);
        layout();
    });

    return { goTo: goTo, next: next, prev: prev };
})();
</script>
}

@section JsonLd {
<script type="application/ld+json">
{
  "@@context": "https://schema.org",
  "@@type": "WebSite",
  "name": @Json.Serialize(ViewData["Title"]?.ToString() ?? ""),
  "url": @Json.Serialize(seoBaseUrl),
  "potentialAction": {
    "@@type": "SearchAction",
    "target": {
      "@@type": "EntryPoint",
      "urlTemplate": @Json.Serialize(seoBaseUrl + "/Products?search={search_term_string}")
    },
    "query-input": "required name=search_term_string"
  }
}
</script>
}