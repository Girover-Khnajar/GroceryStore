@model IReadOnlyList<GroceryStore.Application.Categories.Dtos.CategoryDto>
@using System.Globalization
@using System.Resources
@inject GroceryStore.Web.Services.ImageUrlHelper ImageHelper
@{
    var sharedResourceManager = new ResourceManager("GroceryStore.Web.Shared.SharedResource", typeof(GroceryStore.Web.Controllers.HomeController).Assembly);
    string T(string key) => sharedResourceManager.GetString(key, CultureInfo.CurrentUICulture) ?? key;
    ViewData["Title"] = T("Categories_All");
}

<section class="section" style="padding-top: calc(var(--nav-height) + 2rem);">
    <div class="container">
        <h1 class="section-title">@T("Categories_All")</h1>

        @if (Model.Count == 0)
        {
            <div class="empty-state">
                <i class="fas fa-th-large" style="font-size:3rem;color:var(--border);margin-bottom:1rem;"></i>
                <h3>@T("Categories_EmptyTitle")</h3>
                <p>@T("Categories_EmptySubtitle")</p>
            </div>
        }
        else
        {
            <div class="categories-grid">
                @foreach (var cat in Model)
                {
                    var thumbnailUrl = ImageHelper.GetThumbnailUrl(cat.ImageUrl);
                    <a asp-action="Details" asp-route-slug="@cat.Slug" class="category-card">
                        @await Html.PartialAsync("_OptimizedImage", new OptimizedImageModel {
                            Src = cat.ImageUrl,
                            ThumbnailSrc = thumbnailUrl,
                            Alt = cat.Name,
                            ContainerClass = "category-image",
                            AspectRatio = "4/3",
                            Eager = false,
                            Fallback = "/images/ui/category-placeholder.svg"
                        })
                        <div class="category-info">
                            <h3>@cat.Name</h3>
                        </div>
                    </a>
                }
            </div>
        }
    </div>
</section>
