@model CategoryDetailViewModel
@{
    ViewData["Title"] = Model.Category.Name;
}

<section class="section" style="padding-top: calc(var(--nav-height) + 2rem);">
    <div class="container">
        @* Breadcrumb *@
        <nav class="breadcrumb">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <span style="margin:0 .4rem;">/</span>
            <a asp-controller="Categories" asp-action="Index">Categories</a>
            <span style="margin:0 .4rem;">/</span>
            <span style="color:var(--text);">@Model.Category.Name</span>
        </nav>

        @* Category hero *@
        @if (!string.IsNullOrWhiteSpace(Model.Category.ImageUrl))
        {
            <div style="border-radius:var(--radius-xl);overflow:hidden;aspect-ratio:3/1;margin-bottom:2rem;">
                <img src="@Model.Category.ImageUrl" alt="@Model.Category.Name"
                     style="width:100%;height:100%;object-fit:cover;" />
            </div>
        }

        <h1 class="section-title">@Model.Category.Name</h1>

        @if (!string.IsNullOrWhiteSpace(Model.Category.Description))
        {
            <p style="text-align:center;color:var(--text-light);margin-bottom:2rem;max-width:640px;margin-left:auto;margin-right:auto;">
                @Model.Category.Description
            </p>
        }

        @if (Model.Products.Count == 0)
        {
            <div class="empty-state">
                <i class="fas fa-box-open" style="font-size:3rem;color:var(--border);margin-bottom:1rem;"></i>
                <h3>No products in this category</h3>
                <p>Check back later for new products.</p>
                <a asp-controller="Products" asp-action="Index" class="btn btn-outline" style="margin-top:1rem;">
                    Browse All Products
                </a>
            </div>
        }
        else
        {
            <p style="text-align:center;color:var(--text-light);margin-bottom:1.5rem;">
                @Model.Products.Count product(s) found
            </p>
            <div class="products-grid">
                @foreach (var p in Model.Products)
                {
                    var productImage = $"https://picsum.photos/seed/{Uri.EscapeDataString(p.Slug)}/900/900";

                    <a asp-controller="Products" asp-action="Details" asp-route-slug="@p.Slug"
                       class="product-card">
                        <div class="product-image">
                            <img src="@productImage" alt="@p.Name" loading="lazy" />
                            @if (p.IsFeatured)
                            {
                                <span class="badge-featured"><i class="fas fa-star"></i> Featured</span>
                            }
                        </div>
                        <div class="product-info">
                            <div class="product-name">@p.Name</div>
                            @if (!string.IsNullOrWhiteSpace(p.Brand))
                            {
                                <div class="product-category">@p.Brand</div>
                            }
                            <div class="product-footer">
                                <span class="product-price">@p.PriceAmount.ToString("N2") @p.PriceCurrency</span>
                                <button class="btn-whatsapp" onclick="event.preventDefault();" title="Order via WhatsApp">
                                    <i class="fab fa-whatsapp"></i>
                                </button>
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
    </div>
</section>
