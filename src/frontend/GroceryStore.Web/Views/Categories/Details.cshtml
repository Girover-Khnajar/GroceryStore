@model CategoryDetailViewModel
@using System.Globalization
@using System.Resources
@inject GroceryStore.Web.Services.ImageUrlHelper ImageHelper
@{
    var sharedResourceManager = new ResourceManager("GroceryStore.Web.Shared.SharedResource", typeof(GroceryStore.Web.Controllers.HomeController).Assembly);
    string T(string key) => sharedResourceManager.GetString(key, CultureInfo.CurrentUICulture) ?? key;
    ViewData["Title"] = Model.Category.Name;
}

<section class="section" style="padding-top: calc(var(--nav-height) + 2rem);">
    <div class="container">
        @* Breadcrumb *@
        <nav class="breadcrumb">
            <a asp-controller="Home" asp-action="Index">@T("Nav_Home")</a>
            <span style="margin:0 .4rem;">/</span>
            <a asp-controller="Categories" asp-action="Index">@T("Nav_Categories")</a>
            <span style="margin:0 .4rem;">/</span>
            <span style="color:var(--text);">@Model.Category.Name</span>
        </nav>

        @* Category hero *@
        @if (!string.IsNullOrWhiteSpace(Model.Category.ImageUrl))
        {
            @await Html.PartialAsync("_OptimizedImage", new OptimizedImageModel {
                Src = Model.Category.ImageUrl,
                Alt = Model.Category.Name,
                ContainerStyle = "border-radius:var(--radius-xl);margin-bottom:2rem;",
                AspectRatio = "3/1",
                Eager = true,
                Fallback = "/images/ui/category-placeholder.svg"
            })
        }

        <h1 class="section-title">@Model.Category.Name</h1>

        @if (!string.IsNullOrWhiteSpace(Model.Category.Description))
        {
            <p style="text-align:center;color:var(--text-light);margin-bottom:2rem;max-width:640px;margin-left:auto;margin-right:auto;">
                @Model.Category.Description
            </p>
        }

        @if (Model.Products.Count == 0)
        {
            <div class="empty-state">
                <i class="fas fa-box-open" style="font-size:3rem;color:var(--border);margin-bottom:1rem;"></i>
                <h3>@T("Category_NoProductsTitle")</h3>
                <p>@T("Category_NoProductsSubtitle")</p>
                <a asp-controller="Products" asp-action="Index" class="btn btn-outline" style="margin-top:1rem;">
                    @T("Btn_AllProducts")
                </a>
            </div>
        }
        else
        {
            <p style="text-align:center;color:var(--text-light);margin-bottom:1.5rem;">
                @string.Format(T("Category_ProductsFound"), Model.Products.Count)
            </p>
            <div class="products-grid">
                @foreach (var p in Model.Products)
                {
                    var primaryImageUrl = Model.ProductPrimaryImageUrls.TryGetValue(p.Id, out var resolvedImageUrl)
                        ? resolvedImageUrl
                        : null;
                    var thumbnailUrl = ImageHelper.GetThumbnailUrl(primaryImageUrl);
                    var featuredOverlay = p.IsFeatured ? $"<span class=\"badge-featured\"><i class=\"fas fa-star\"></i> {T("Badge_Featured")}</span>" : null;
                    
                    <a asp-controller="Products" asp-action="Details" asp-route-slug="@p.Slug"
                       class="product-card">
                        @await Html.PartialAsync("_OptimizedImage", new OptimizedImageModel {
                            Src = primaryImageUrl,
                            ThumbnailSrc = thumbnailUrl,
                            Alt = p.Name,
                            ContainerClass = "product-image",
                            AspectRatio = "1/1",
                            Eager = false,
                            Fallback = "/images/ui/product-placeholder.svg",
                            ShowOverlay = p.IsFeatured,
                            OverlayContent = featuredOverlay
                        })
                        <div class="product-info">
                            <div class="product-name">@p.Name</div>
                            @if (!string.IsNullOrWhiteSpace(p.Brand))
                            {
                                <div class="product-category">@p.Brand</div>
                            }
                            <div class="product-footer">
                                <span class="product-price">
                                    @p.PriceAmount.ToString("N2") @p.PriceCurrency
                                    @if (!string.IsNullOrWhiteSpace(p.Unit))
                                    {
                                        <span style="color:var(--text-light);font-size:.85rem;">/ @p.Unit</span>
                                    }
                                </span>
                                <button type="button" class="btn-whatsapp" onclick="addToCart(event, '@p.Id')" title="@T("Title_AddToCart")">
                                    <i class="fas fa-cart-plus"></i>
                                </button>
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
    </div>
</section>
