@using GroceryStore.Web.Services.Localization
@using System.Globalization
@using System.Resources
@inject GroceryStore.Web.Services.IStoreSettingsService StoreSettingsService
@inject GroceryStore.Web.Services.ICartService CartService
@{
    var sharedResourceManager = new ResourceManager("GroceryStore.Web.Shared.SharedResource", typeof(GroceryStore.Web.Controllers.HomeController).Assembly);
    string T(string key) => sharedResourceManager.GetString(key, CultureInfo.CurrentUICulture) ?? key;
    var footerSettings = await StoreSettingsService.GetAsync();
    var cartItemCount = CartService.GetCount();
    var footerHours = (footerSettings.OpeningHours ?? string.Empty)
        .Split(new[] { "\r\n", "\n" }, StringSplitOptions.RemoveEmptyEntries)
        .Select(x => x.Trim())
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .ToList();
    
    // Localization: Get current culture and check if RTL
    var currentCulture = Context.GetCurrentCulture();
    var isRtl = GroceryStore.Web.Services.Localization.CultureHelper.IsRtlCulture(currentCulture);
}

<!DOCTYPE html>
<html lang="@currentCulture" dir="@(isRtl ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @footerSettings.StoreName</title>

    @* Prevent theme flash *@
    <script>
        (function () {
            var t = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-theme', t);
        })();
    </script>

    @* Google Fonts *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    @* Font Awesome 6.4 *@
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    @* App styles *@
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    
    @* RTL Support for Arabic *@
    @if (isRtl)
    {
        <link rel="stylesheet" href="~/css/rtl.css" asp-append-version="true" />
    }
</head>
<body>
    @* ═══ Navbar ═══ *@
    <nav class="navbar" id="navbar">
        <div class="container nav-wrapper">
            <a asp-controller="Home" asp-action="Index" class="logo">
                <img src="~/images/logo-2.png" alt="@footerSettings.StoreName" class="logo-img" />
                <span>@footerSettings.StoreName</span>
            </a>

            <div class="nav-menu" id="navMenu">
                <a asp-controller="Home" asp-action="Index" class="nav-link">
                    <i class="fas fa-home"></i> @T("Nav_Home")
                </a>
                <a asp-controller="Categories" asp-action="Index" class="nav-link">
                    <i class="fas fa-th-large"></i> @T("Nav_Categories")
                </a>
                <a asp-controller="Products" asp-action="Index" class="nav-link">
                    <i class="fas fa-box-open"></i> @T("Nav_Products")
                </a>
                <a asp-controller="Cart" asp-action="Index" class="nav-link">
                    <i class="fas fa-shopping-cart"></i> @T("Nav_Cart")
                    @if (cartItemCount > 0)
                    {
                        <span class="cart-badge">@cartItemCount</span>
                    }
                </a>
                <a asp-controller="Home" asp-action="Contact" class="nav-link">
                    <i class="fas fa-envelope"></i> @T("Nav_Contact")
                </a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Admin" asp-action="Dashboard" class="nav-link nav-link-dashboard">
                        <i class="fas fa-tachometer-alt"></i> @T("Nav_Admin")
                    </a>
                }

                @* ── Mobile-only extras (theme + language) ─────────────────── *@
                <div class="nav-menu-extras">
                    <button class="menu-extra-btn menu-theme-btn" id="menuThemeToggle" onclick="toggleTheme()" title="@T("Ui_ToggleTheme")">
                        <i class="fas fa-moon menu-icon-moon"></i>
                        <i class="fas fa-sun menu-icon-sun" style="display:none"></i>
                        <span>@T("Ui_ToggleTheme")</span>
                    </button>
                    <div class="menu-lang-switcher">
                        <button class="menu-extra-btn" id="menuLanguageToggle" title="@T("Lbl_Language")">
                            <i class="fas fa-globe"></i>
                            <span>@currentCulture.ToUpper()</span>
                        </button>
                        <div class="language-dropdown menu-language-dropdown" id="menuLanguageDropdown" style="display:none;">
                            @foreach (var (code, displayName, isRtl) in GroceryStore.Web.Services.Localization.CultureHelper.GetAvailableCultures())
                            {
                                var isActive = code == currentCulture;
                                <a href="@Url.Action("SetCulture", "Culture", new { culture = code, returnUrl = Context.Request.Path + Context.Request.QueryString })"
                                   class="language-item @(isActive ? "active" : "")"
                                   data-culture="@code">
                                    <span class="lang-name">@displayName</span>
                                    @if (isActive)
                                    {
                                        <i class="fas fa-check"></i>
                                    }
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="nav-actions">
                <div class="language-switcher">
                    <button class="language-toggle" id="languageToggle" title="@T("Lbl_Language")">
                        <i class="fas fa-globe"></i>
                        <span class="lang-code">@currentCulture.ToUpper()</span>
                    </button>
                    <div class="language-dropdown" id="languageDropdown" style="display:none;">
                        @foreach (var (code, displayName, isRtl) in GroceryStore.Web.Services.Localization.CultureHelper.GetAvailableCultures())
                        {
                            var isActive = code == currentCulture;
                            <a href="@Url.Action("SetCulture", "Culture", new { culture = code, returnUrl = Context.Request.Path + Context.Request.QueryString })"
                               class="language-item @(isActive ? "active" : "")"
                               data-culture="@code">
                                <span class="lang-name">@displayName</span>
                                @if (isActive)
                                {
                                    <i class="fas fa-check"></i>
                                }
                            </a>
                        }
                    </div>
                </div>

                <button class="theme-toggle" onclick="toggleTheme()" title="@T("Ui_ToggleTheme")">
                    <i class="fas fa-moon"></i>
                    <i class="fas fa-sun"></i>
                </button>
                <a asp-controller="Cart" asp-action="Index" class="nav-cart-btn" title="@T("Nav_Cart")">
                    <i class="fas fa-shopping-cart"></i>
                    @if (cartItemCount > 0)
                    {
                        <span class="cart-badge">@cartItemCount</span>
                    }
                </a>
                <button class="menu-toggle" onclick="toggleMenu()" title="@T("Ui_Menu")">
                    <i class="fas fa-bars"></i>
                    <i class="fas fa-times" style="display:none"></i>
                </button>
            </div>

            @* ── Second row: always-visible search bar ── *@
            <form asp-controller="Products" asp-action="Index" method="get" class="header-search-bar">
                <input type="text" name="search" placeholder="@T("Search_Placeholder")" autocomplete="off" class="header-search-input" />
                <button type="submit" class="header-search-btn">
                    <i class="fas fa-search"></i>
                </button>
            </form>
        </div>
    </nav>

    @* ═══ Toast ═══ *@
    @{
        var toastMsg = TempData["Success"] as string ?? TempData["Error"] as string;
        var toastType = TempData["Success"] != null ? "success" : (TempData["Error"] != null ? "error" : "");
    }
    <div class="toast" id="toast"
         data-message="@toastMsg"
         data-type="@toastType">
        <i class="fas fa-check-circle"></i>
        <span></span>
    </div>

    @* ═══ Main Content ═══ *@
    <main>
        @RenderBody()
    </main>

    @* ═══ Footer ═══ *@
    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                @* Brand *@
                <div class="footer-section">
                    <h3><img src="~/images/logo-2.png" alt="@footerSettings.StoreName" class="logo-img" /> @footerSettings.StoreName</h3>
                    <p>@T("Footer_Description")</p>
                    <div class="social-links">
                        <a href="#" title="Facebook"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" title="Instagram"><i class="fab fa-instagram"></i></a>
                        <a href="#" title="Twitter"><i class="fab fa-twitter"></i></a>
                        <a href="#" title="WhatsApp"><i class="fab fa-whatsapp"></i></a>
                    </div>
                </div>

                @* Quick Links *@
                <div class="footer-section">
                    <h4>@T("Footer_QuickLinks")</h4>
                    <ul>
                        <li><a asp-controller="Home" asp-action="Index">@T("Nav_Home")</a></li>
                        <li><a asp-controller="Categories" asp-action="Index">@T("Nav_Categories")</a></li>
                        <li><a asp-controller="Products" asp-action="Index">@T("Nav_Products")</a></li>
                        <li><a asp-controller="Cart" asp-action="Index">@T("Nav_Cart")</a></li>
                        <li><a asp-controller="Home" asp-action="Contact">@T("Footer_ContactUs")</a></li>
                        @if (User.Identity?.IsAuthenticated != true)
                        {
                            <li><a asp-controller="Account" asp-action="Login">@T("Nav_Login")</a></li>
                        }
                    </ul>
                </div>

                @* Contact Info *@
                <div class="footer-section">
                    <h4>@T("Footer_ContactUs")</h4>
                    <ul class="contact-info">
                        <li><i class="fas fa-phone"></i> <span>@footerSettings.Phone</span></li>
                        <li><i class="fab fa-whatsapp"></i> <span>@footerSettings.WhatsappNumber</span></li>
                        <li><i class="fas fa-envelope"></i> <span>@footerSettings.Email</span></li>
                        <li><i class="fas fa-map-marker-alt"></i> <span>@footerSettings.Address</span></li>
                    </ul>
                </div>

                @* Opening Hours *@
                <div class="footer-section">
                    <h4>@T("Footer_OpeningHours")</h4>
                    <ul>
                        @if (footerHours.Count == 0)
                        {
                            <li>@T("Footer_OpeningHoursNotSet")</li>
                        }
                        else
                        {
                            foreach (var line in footerHours)
                            {
                                <li>@line</li>
                            }
                        }
                    </ul>
                </div>
            </div>

            <div class="footer-bottom">
                <p>&copy; @DateTime.UtcNow.Year @footerSettings.StoreName. @T("Footer_AllRightsReserved")</p>
                <p>@T("Footer_BuiltWith") <i class="fas fa-heart" style="color:var(--danger);"></i> @T("Footer_ByTeam")</p>
            </div>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    
    @* ── Language Switcher ────────────────────────────────────────────────── *@
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            function wireLanguageDropdown(toggleId, dropdownId, closeSelectorFn) {
                const btn = document.getElementById(toggleId);
                const dd  = document.getElementById(dropdownId);
                if (!btn || !dd) return;
                btn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    dd.style.display = dd.style.display === 'none' ? 'block' : 'none';
                });
                document.addEventListener('click', function (e) {
                    if (!closeSelectorFn(e.target)) dd.style.display = 'none';
                });
                dd.querySelectorAll('.language-item').forEach(function (item) {
                    item.addEventListener('click', function () { dd.style.display = 'none'; });
                });
            }

            // Navbar language dropdown (desktop)
            wireLanguageDropdown('languageToggle', 'languageDropdown',
                function (t) { return t.closest('.language-switcher'); });

            // Menu language dropdown (mobile)
            wireLanguageDropdown('menuLanguageToggle', 'menuLanguageDropdown',
                function (t) { return t.closest('.menu-lang-switcher'); });

            // Sync moon/sun icons in the menu theme button with current theme
            function syncMenuThemeIcons() {
                var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
                var moon = document.querySelector('.menu-icon-moon');
                var sun  = document.querySelector('.menu-icon-sun');
                if (moon) moon.style.display = isDark ? 'none' : '';
                if (sun)  sun.style.display  = isDark ? '' : 'none';
            }
            syncMenuThemeIcons();
            var menuThemeBtn = document.getElementById('menuThemeToggle');
            if (menuThemeBtn) {
                menuThemeBtn.addEventListener('click', function () {
                    setTimeout(syncMenuThemeIcons, 0);
                });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)

    @* ── Cookie Consent Banner ──────────────────────────────────────────── *@
    <div id="cookieBanner" class="cookie-banner" role="dialog" aria-live="polite" aria-label="Cookie consent" style="display:none;">
        <div class="cookie-banner-inner">
            <div class="cookie-banner-top">
                <i class="fas fa-cookie-bite"></i>
                <p>
                    @T("Cookie_Message")
                    <a href="/privacy" class="cookie-learn-more">@T("Cookie_PrivacyNotes")</a>
                </p>
            </div>
            <div class="cookie-banner-actions">
                <button id="cookieDecline"   class="cookie-btn cookie-btn-decline">@T("Cookie_Decline")</button>
                <button id="cookieEssential" class="cookie-btn cookie-btn-essential">@T("Cookie_AcceptEssential")</button>
                <button id="cookieAcceptAll" class="cookie-btn cookie-btn-accept">@T("Cookie_AcceptAll")</button>
            </div>
        </div>
    </div>
    <script>
        (function () {
            var KEY = 'cookie_consent';
            var banner = document.getElementById('cookieBanner');
            if (!banner) return;
            if (!localStorage.getItem(KEY)) {
                banner.style.display = 'block';
                setTimeout(function () { banner.classList.add('cookie-banner--visible'); }, 100);
            }
            document.getElementById('cookieAcceptAll').addEventListener('click', function () {
                localStorage.setItem(KEY, 'all');
                hideBanner();
            });
            document.getElementById('cookieEssential').addEventListener('click', function () {
                localStorage.setItem(KEY, 'essential');
                hideBanner();
            });
            document.getElementById('cookieDecline').addEventListener('click', function () {
                localStorage.setItem(KEY, 'declined');
                hideBanner();
            });
            function hideBanner() {
                banner.classList.remove('cookie-banner--visible');
                setTimeout(function () { banner.style.display = 'none'; }, 350);
            }
        })();
    </script>
</body>
</html>
