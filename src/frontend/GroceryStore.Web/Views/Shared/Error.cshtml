@using System.Globalization
@using System.Resources
@{
    var sharedResourceManager = new ResourceManager("GroceryStore.Web.Shared.SharedResource", typeof(GroceryStore.Web.Controllers.HomeController).Assembly);
    string T(string key) => sharedResourceManager.GetString(key, CultureInfo.CurrentUICulture) ?? key;
    ViewData["Title"] = T("Page_Error");
}

<section class="section" style="text-align:center; padding:5rem 0;">
    <i class="fas fa-exclamation-triangle" style="font-size:5rem; color:#d97706;"></i>
    <h1 style="margin-top:1.5rem; font-size:3rem;">@T("Error_Oops")</h1>
    <p style="color:#6b7280; font-size:1.2rem; margin:1rem 0;">@T("Error_GenericMessage")</p>
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
        <i class="fas fa-home"></i> @T("Btn_Home")
    </a>
</section>
